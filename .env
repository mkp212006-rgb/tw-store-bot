# Crie seu bot no Telegram com o @BotFather e cole o token aqui
TELEGRAM_BOT_TOKEN=COLE_AQUI_O_TOKEN_DO_BOT

# Seu WhatsApp em formato internacional, sem +, espaços ou traços
ADMIN_WHATSAPP=5512997793285

# Para WhatsApp automático via CallMeBot: obtenha a API key e cole aqui
# Sem essa chave, o bot ainda funciona, mas não envia WhatsApp automaticamente.
CALLMEBOT_APIKEY=COLE_AQUI_SUA_APIKEY

# Opcional: seu ID do Telegram para também receber o resumo por Telegram
ADMIN_TELEGRAM_ID=8501191385
