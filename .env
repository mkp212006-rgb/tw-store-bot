# =========================
# TELEGRAM
# =========================
BOT_TOKEN=8833072850:AAHkHd4W80Vp31kBTrxyIaFvA_V3zQL5MjA
ADMIN_CHAT_ID=8501191385

# Novo na versão 1.5:
# Segundo admin pode aprovar/negar cadastros e acessar /painel.
# Ele NÃO recebe relatórios financeiros/pedidos; isso continua com o ADMIN_CHAT_ID.
# Como nenhum segundo admin foi informado, ficou vazio.
