MP_WEBHOOK_SECRET=96c6961e2b11cb21be7a02c969e47b9a8070af182a656555c01a87ce42b1afe6

# Fila persistente para reprocessar webhooks pendentes.
WEBHOOK_QUEUE_INTERVAL=45
