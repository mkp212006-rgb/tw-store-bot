PIX_RECEBEDOR=Mayk Do Espirito Santo Fernandes

# =========================
# API DA PLATAFORMA SMM
# Necessário para envio automático de pedidos Instagram/TikTok.
# =========================
PANEL_API_URL=https://morethanpanel.com/api/v2
PANEL_API_KEY=5301b59b58ccff81602de9c82f8ce3e8
