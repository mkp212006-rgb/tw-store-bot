# =========================
# MERCADO PAGO — PIX AUTOMÁTICO
# =========================
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-4871479039991509-062903-f06fc5b82ae175d47ca3103d34d4858d-1680979129
